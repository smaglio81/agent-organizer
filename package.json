{
  "name": "agent-organizer",
  "displayName": "Agent Organizer",
  "description": "Agent Organizer Marketplace and Toolkit",
  "version": "0.0.4",
  "icon": "resources/logo.png",
  "publisher": "smaglio81",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "AI"
  ],
  "keywords": [
    "agent",
    "skills",
    "marketplace",
    "ai",
    "claude"
  ],
  "bugs": {
    "url": "https://github.com/smaglio81/agent-organizer/issues",
    "email": "smaglio81@gmail.com"
  },
  "homepage": "https://github.com/smaglio81/agent-organizer/blob/main/README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/smaglio81/agent-organizer.git"
  },
  "activationEvents": [
    "onView:agentOrganizer.marketplace",
    "onView:agentOrganizer.skills"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agent-organizer",
          "title": "Agent Organizer",
          "icon": "resources/skills-icon.svg"
        }
      ]
    },
    "views": {
      "agent-organizer": [
        {
          "id": "agentOrganizer.marketplace",
          "name": "Marketplace"
        },
        {
          "id": "agentOrganizer.skills",
          "name": "Skills"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "agentOrganizer.skills",
        "contents": "Loading ...",
        "when": "!agentOrganizer:initialScanComplete"
      },
      {
        "view": "agentOrganizer.skills",
        "contents": "No skills installed yet.\n[Browse Marketplace](command:agentOrganizer.focusMarketplace)",
        "when": "agentOrganizer:initialScanComplete"
      }
    ],
    "commands": [
      {
        "command": "agentOrganizer.install",
        "title": "Install Skill",
        "icon": "$(cloud-download)"
      },
      {
        "command": "agentOrganizer.uninstall",
        "title": "Delete",
        "icon": "$(trash)"
      },
      {
        "command": "agentOrganizer.refresh",
        "title": "Refresh Marketplace",
        "icon": "$(refresh)"
      },
      {
        "command": "agentOrganizer.refreshInstalled",
        "title": "Refresh Installed Skills",
        "icon": "$(refresh)"
      },
      {
        "command": "agentOrganizer.viewDetails",
        "title": "View Skill Details",
        "icon": "$(info)"
      },
      {
        "command": "agentOrganizer.removeRepository",
        "title": "Delete",
        "icon": "$(trash)"
      },
      {
        "command": "agentOrganizer.addRepository",
        "title": "Add Repository",
        "icon": "$(add)"
      },
      {
        "command": "agentOrganizer.search",
        "title": "Search Marketplace Skills",
        "icon": "$(search)"
      },
      {
        "command": "agentOrganizer.clearSearch",
        "title": "Clear Marketplace Search",
        "icon": "$(close)"
      },
      {
        "command": "agentOrganizer.openSkillFolder",
        "title": "Open Skill Folder",
        "icon": "$(folder-opened)"
      },
      {
        "command": "agentOrganizer.moveSkill",
        "title": "Move to..."
      },
      {
        "command": "agentOrganizer.copySkill",
        "title": "Copy to..."
      },
      {
        "command": "agentOrganizer.syncSkill",
        "title": "Update older skill copies with latest"
      },
      {
        "command": "agentOrganizer.getLatestSkill",
        "title": "Get latest copy of skill"
      },
      {
        "command": "agentOrganizer.deleteAllSkills",
        "title": "Delete"
      },
      {
        "command": "agentOrganizer.showInMarketplace",
        "title": "Show in Marketplace"
      },
      {
        "command": "agentOrganizer.openInBrowser",
        "title": "Open in Browser",
        "icon": "$(link-external)"
      },
      {
        "command": "agentOrganizer.revealInFileExplorer",
        "title": "Reveal in File Explorer"
      },
      {
        "command": "agentOrganizer.searchInstalled",
        "title": "Search Installed Skills",
        "icon": "$(search)"
      },
      {
        "command": "agentOrganizer.clearSearchInstalled",
        "title": "Clear Installed Search",
        "icon": "$(close)"
      },
      {
        "command": "agentOrganizer.focusMarketplace",
        "title": "Focus Marketplace View"
      },
      {
        "command": "agentOrganizer.selectInstallLocation",
        "title": "Install Location",
        "icon": "$(folder)"
      },
      {
        "command": "agentOrganizer.expandAll",
        "title": "Expand All",
        "icon": "$(expand-all)"
      },
      {
        "command": "agentOrganizer.collapseAll",
        "title": "Collapse All",
        "icon": "$(collapse-all)"
      },
      {
        "command": "agentOrganizer.addFile",
        "title": "Add File",
        "icon": "$(new-file)"
      },
      {
        "command": "agentOrganizer.addFolder",
        "title": "Add Folder",
        "icon": "$(new-folder)"
      },
      {
        "command": "agentOrganizer.renameFile",
        "title": "Rename",
        "icon": "$(edit)"
      },
      {
        "command": "agentOrganizer.deleteSkillFile",
        "title": "Delete",
        "icon": "$(trash)"
      },
      {
        "command": "agentOrganizer.deleteSkillFolder",
        "title": "Delete",
        "icon": "$(trash)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "agentOrganizer.addRepository",
          "when": "view == agentOrganizer.marketplace",
          "group": "navigation@0"
        },
        {
          "command": "agentOrganizer.search",
          "when": "view == agentOrganizer.marketplace",
          "group": "navigation@1"
        },
        {
          "command": "agentOrganizer.clearSearch",
          "when": "view == agentOrganizer.marketplace && agentOrganizer:searchActive",
          "group": "navigation@1"
        },
        {
          "command": "agentOrganizer.refresh",
          "when": "view == agentOrganizer.marketplace",
          "group": "navigation@2"
        },
        {
          "command": "agentOrganizer.refreshInstalled",
          "when": "view == agentOrganizer.skills",
          "group": "navigation@2"
        },
        {
          "command": "agentOrganizer.searchInstalled",
          "when": "view == agentOrganizer.skills",
          "group": "navigation@1"
        },
        {
          "command": "agentOrganizer.clearSearchInstalled",
          "when": "view == agentOrganizer.skills && agentOrganizer:installedSearchActive",
          "group": "navigation@1"
        },
        {
          "command": "agentOrganizer.selectInstallLocation",
          "when": "view == agentOrganizer.skills",
          "group": "navigation@3"
        },
        {
          "command": "agentOrganizer.expandAll",
          "when": "view == agentOrganizer.skills",
          "group": "navigation@4"
        },
        {
          "command": "agentOrganizer.collapseAll",
          "when": "view == agentOrganizer.skills",
          "group": "navigation@5"
        }
      ],
      "view/item/context": [
        {
          "command": "agentOrganizer.install",
          "when": "view == agentOrganizer.marketplace && viewItem == skill",
          "group": "inline@1"
        },
        {
          "command": "agentOrganizer.install",
          "when": "view == agentOrganizer.marketplace && viewItem == skill",
          "group": "1_install@1"
        },
        {
          "command": "agentOrganizer.viewDetails",
          "when": "view == agentOrganizer.marketplace && viewItem == skill",
          "group": "inline@2"
        },
        {
          "command": "agentOrganizer.removeRepository",
          "when": "view == agentOrganizer.marketplace && (viewItem == source || viewItem == failedSource)",
          "group": "inline@1"
        },
        {
          "command": "agentOrganizer.openInBrowser",
          "when": "view == agentOrganizer.marketplace && (viewItem == source || viewItem == failedSource)",
          "group": "0_open@1"
        },
        {
          "command": "agentOrganizer.openInBrowser",
          "when": "view == agentOrganizer.marketplace && viewItem == skill",
          "group": "2_open@1"
        },
        {
          "command": "agentOrganizer.removeRepository",
          "when": "view == agentOrganizer.marketplace && (viewItem == source || viewItem == failedSource)",
          "group": "1_delete@1"
        },
        {
          "command": "agentOrganizer.addFile",
          "when": "view == agentOrganizer.skills && (viewItem =~ /^installedSkill/ || viewItem == skillFolder)",
          "group": "0_add@1"
        },
        {
          "command": "agentOrganizer.addFolder",
          "when": "view == agentOrganizer.skills && (viewItem =~ /^installedSkill/ || viewItem == skillFolder)",
          "group": "0_add@2"
        },
        {
          "command": "agentOrganizer.renameFile",
          "when": "view == agentOrganizer.skills && viewItem == skillFile",
          "group": "0_rename@1"
        },
        {
          "command": "agentOrganizer.deleteSkillFile",
          "when": "view == agentOrganizer.skills && viewItem == skillFile",
          "group": "2_delete@1"
        },
        {
          "command": "agentOrganizer.deleteSkillFolder",
          "when": "view == agentOrganizer.skills && viewItem == skillFolder",
          "group": "2_delete@1"
        },
        {
          "command": "agentOrganizer.moveSkill",
          "when": "view == agentOrganizer.skills && viewItem =~ /^installedSkill/",
          "group": "1_move@1"
        },
        {
          "command": "agentOrganizer.copySkill",
          "when": "view == agentOrganizer.skills && viewItem =~ /^installedSkill/",
          "group": "1_move@2"
        },
        {
          "command": "agentOrganizer.syncSkill",
          "when": "view == agentOrganizer.skills && viewItem == installedSkill_newest",
          "group": "1_move@3"
        },
        {
          "command": "agentOrganizer.getLatestSkill",
          "when": "view == agentOrganizer.skills && viewItem == installedSkill_older",
          "group": "1_move@4"
        },
        {
          "command": "agentOrganizer.uninstall",
          "when": "view == agentOrganizer.skills && viewItem =~ /^installedSkill/",
          "group": "inline@1"
        },
        {
          "command": "agentOrganizer.uninstall",
          "when": "view == agentOrganizer.skills && viewItem =~ /^installedSkill/",
          "group": "2_delete@1"
        },
        {
          "command": "agentOrganizer.openSkillFolder",
          "when": "view == agentOrganizer.skills && viewItem =~ /^installedSkill/",
          "group": "inline@2"
        },
        {
          "command": "agentOrganizer.showInMarketplace",
          "when": "view == agentOrganizer.skills && viewItem =~ /^installedSkill/",
          "group": "3_marketplace@1"
        },
        {
          "command": "agentOrganizer.deleteAllSkills",
          "when": "view == agentOrganizer.skills && viewItem == location",
          "group": "1_delete@1"
        },
        {
          "command": "agentOrganizer.revealInFileExplorer",
          "when": "view == agentOrganizer.skills && viewItem == location",
          "group": "1_delete@2"
        },
        {
          "command": "agentOrganizer.revealInFileExplorer",
          "when": "view == agentOrganizer.skills && viewItem =~ /^installedSkill/",
          "group": "0_add@3"
        },
        {
          "command": "agentOrganizer.revealInFileExplorer",
          "when": "view == agentOrganizer.skills && viewItem == skillFolder",
          "group": "0_add@3"
        },
        {
          "command": "agentOrganizer.revealInFileExplorer",
          "when": "view == agentOrganizer.skills && viewItem == skillFile",
          "group": "0_rename@2"
        }
      ]
    },
    "configuration": {
      "title": "Agent Organizer",
      "properties": {
        "agentOrganizer.skillRepositories": {
          "type": "array",
          "default": [
            {
              "owner": "anthropics",
              "repo": "skills",
              "path": "skills",
              "branch": "main"
            },
            {
              "owner": "github",
              "repo": "awesome-copilot",
              "path": "skills",
              "branch": "main"
            },
            {
              "owner": "pytorch",
              "repo": "pytorch",
              "path": ".claude/skills",
              "branch": "main"
            },
            {
              "owner": "openai",
              "repo": "skills",
              "path": "skills/.curated",
              "branch": "main"
            },
            {
              "owner": "microsoftdocs",
              "repo": "mcp",
              "path": "skills",
              "branch": "main"
            },
            {
              "owner": "formulahendry",
              "repo": "agent-skill-code-runner",
              "path": ".github/skills/code-runner",
              "branch": "main",
              "singleSkill": true
            }
          ],
          "description": "GitHub repositories to fetch skills from",
          "items": {
            "type": "object",
            "properties": {
              "owner": {
                "type": "string",
                "description": "GitHub repository owner"
              },
              "repo": {
                "type": "string",
                "description": "GitHub repository name"
              },
              "path": {
                "type": "string",
                "description": "Path to skills directory within the repo"
              },
              "branch": {
                "type": "string",
                "default": "main",
                "description": "Branch name"
              },
              "singleSkill": {
                "type": "boolean",
                "default": false,
                "description": "If true, the path points directly to a single skill folder"
              }
            },
            "required": [
              "owner",
              "repo",
              "path"
            ]
          }
        },
        "agentOrganizer.installLocation": {
          "type": "string",
          "default": ".github/skills",
          "description": "Where to install skills: in the current workspace or in the user's home directory (~/). It is recommended to use one of the locations defined in chat.agentSkillsLocations so that installed skills are detected correctly."
        },
        "agentOrganizer.githubToken": {
          "type": "string",
          "default": "",
          "description": "GitHub personal access token for higher API rate limits (optional)",
          "scope": "application"
        },
        "agentOrganizer.cacheTimeout": {
          "type": "number",
          "default": 3600,
          "description": "Cache timeout for marketplace data in seconds"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "package:vsix": "npx vsce package",
    "install:vsix": "npx vsce package && node -e \"const fs=require('fs'); const files=fs.readdirSync('.').filter(f=>f.startsWith('agent-organizer-')&&f.endsWith('.vsix')).sort(); if(files.length) require('child_process').execSync('code --install-extension '+files[files.length-1], {stdio:'inherit'});\"",
    "uninstall:vsix": "code --uninstall-extension formulahendry.agent-organizer",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.107.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.1",
    "eslint": "^9.39.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1"
  },
  "dependencies": {
    "@types/markdown-it": "^14.1.2",
    "markdown-it": "^14.1.0"
  }
}
